# Copy this file to `.env` and edit.
#
# GEM5_SRC must be an absolute path to your gem5 source clone. The
# container mounts it at /gem5 and builds ARM_MESI_Two_Level inside.
#
# Why not vendor gem5 into this repo? Because gem5's git history is
# large and pinning via submodule forces its size on everyone who just
# wants to poke at Phase 1. If you do want a submodule, add it yourself
# (e.g., `git submodule add https://github.com/gem5/gem5.git gem5-src`)
# and set GEM5_SRC=$(pwd)/../../../gem5-src.

GEM5_SRC=/absolute/path/to/gem5
